# Environment variables for Vaultstone contracts deployment

# Deployer private key (without 0x prefix)
PRIVATE_KEY=

# Admin address for contract management
ADMIN_ADDRESS=

# Address to receive platform fees
FEE_RECIPIENT_ADDRESS=

# Platform fee in basis points (100 = 1%)
PLATFORM_FEE=100

# Polkadot Hub Testnet RPC URL
POLKADOT_HUB_TESTNET_RPC_URL=

# Block explorer API key for verification
ETHERSCAN_API_KEY=
